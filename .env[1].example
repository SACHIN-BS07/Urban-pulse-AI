# Twilio Credentials for SMS Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP Credentials for Emergency Emails
# IMPORTANT: SMTP_HOST must be a hostname like smtp.gmail.com, NOT an email address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMERGENCY_EMAIL_RECIPIENT=police-hospital@example.com
